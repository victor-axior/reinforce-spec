# Reinforce-Spec environment variables
# Copy to .env and fill in values

# ── Required ──────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── LLM Configuration ────────────────────────────────────────────────────────
# Primary model for spec generation
RS_GENERATION_MODEL=anthropic/claude-sonnet-4
# Judge models (comma-separated for multi-judge ensemble)
RS_JUDGE_MODELS=anthropic/claude-sonnet-4,openai/gpt-4o,google/gemini-2.0-flash-001
# Fallback model chain
RS_FALLBACK_MODELS=anthropic/claude-sonnet-4,openai/gpt-4o,google/gemini-2.0-flash-001

# ── Server ────────────────────────────────────────────────────────────────────
RS_HOST=0.0.0.0
RS_PORT=8000
RS_WORKERS=4
RS_LOG_LEVEL=info
RS_LOG_FORMAT=json
RS_API_KEY=  # Leave empty to disable auth in development

# ── RL Policy ─────────────────────────────────────────────────────────────────
RS_POLICY_WEIGHTS_DIR=data/weights
RS_COLD_START_THRESHOLD=200
RS_SHADOW_THRESHOLD=500
RS_EXPLORE_RATE_INITIAL=0.15
RS_EXPLORE_RATE_MIN=0.02
RS_EXPLORE_DECAY=0.995
RS_RETRAIN_BATCH_SIZE=50

# ── Scoring ───────────────────────────────────────────────────────────────────
RS_SCORING_MODE=multi_judge          # single_judge | multi_judge
RS_CALIBRATION_ENABLED=true
RS_PAIRWISE_TOP_K=3

# ── Resilience ────────────────────────────────────────────────────────────────
RS_LLM_TIMEOUT_SECONDS=30
RS_LLM_MAX_RETRIES=3
RS_CIRCUIT_BREAKER_THRESHOLD=5
RS_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
RS_MAX_CONCURRENT_REQUESTS=50
RS_BACKPRESSURE_P99_SLO_SECONDS=30

# ── Storage ───────────────────────────────────────────────────────────────────
RS_DATABASE_URL=sqlite+aiosqlite:///data/db/reinforce_spec.db
RS_REDIS_URL=  # Leave empty for in-memory fallback
RS_IDEMPOTENCY_TTL_SECONDS=86400

# ── Observability ─────────────────────────────────────────────────────────────
RS_METRICS_ENABLED=true
RS_MLFLOW_TRACKING_URI=  # Leave empty to disable
RS_AUDIT_LOG_RETENTION_DAYS=2555      # ~7 years
